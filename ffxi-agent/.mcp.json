{
  "mcpServers": {
    "ffxi": {
      "command": "cargo",
      "args": ["run", "--release", "--manifest-path", "../Cargo.toml", "-p", "ffxi-mcp"],
      "env": {
        "FFXI_SERVER": "127.0.0.1",
        "FFXI_AUTH_PORT": "54231",
        "FFXI_DATA_PORT": "54230",
        "FFXI_VIEW_PORT": "54001",
        "FFXI_USER": "${FFXI_USER}",
        "FFXI_PASS": "${FFXI_PASS}",
        "FFXI_CHAR": "${FFXI_CHAR}",
        "RUST_LOG": "info"
      }
    }
  }
}
