{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__ffxi__*",
      "Read(//Users/jon/.config/ffxi-mcp/**)",
      "Read(//Volumes/Sidecar/ffxi/ffxi-agent/playbooks/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/stop-keep-playing.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-bootstrap.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
