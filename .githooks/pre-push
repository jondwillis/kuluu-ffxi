#!/usr/bin/env bash
# Pre-push gate that mirrors .github/workflows/ci.yml so a red CI is caught
# locally before the push. Checks the working tree (what you'd push next).
#
# Bypass once:   git push --no-verify
# Bypass via env: SKIP_PREPUSH=1 git push
# Skip the slow clippy pass: PREPUSH_FAST=1 git push   (runs fmt only)
#
# Install (per clone): scripts/install-hooks.sh   (sets core.hooksPath=.githooks)
set -euo pipefail

if [[ "${SKIP_PREPUSH:-}" == "1" ]]; then
  echo "pre-push: skipped (SKIP_PREPUSH=1)"
  exit 0
fi

cd "$(git rev-parse --show-toplevel)"

# Match CI exactly so a green hook means a green CI fmt/clippy.
FEATURES=(--features native-window)

echo "pre-push: cargo fmt --all --check"
if ! cargo fmt --all --check; then
  echo "pre-push: ✗ formatting — run 'cargo fmt --all' (or 'git push --no-verify' to bypass)" >&2
  exit 1
fi

if [[ "${PREPUSH_FAST:-}" == "1" ]]; then
  echo "pre-push: ok (fmt only; PREPUSH_FAST=1)"
  exit 0
fi

# --all-targets also compiles tests/examples, so stale constructors and broken
# examples surface here (not just lints). --locked catches an out-of-date lockfile.
echo "pre-push: cargo clippy --workspace --all-targets --locked ${FEATURES[*]} -- -D warnings"
if ! cargo clippy --workspace --all-targets --locked "${FEATURES[@]}" -- -D warnings; then
  echo "pre-push: ✗ clippy — fix the warnings above (or 'git push --no-verify' to bypass)" >&2
  exit 1
fi

echo "pre-push: ok"
